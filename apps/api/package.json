{
  "name": "@chorus/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.prod.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@chorus/graph-utils": "*",
    "@chorus/shared-types": "*",
    "@chorus/tree-sitter-utils": "*",
    "@octokit/rest": "^20.0.0",
    "bullmq": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.41.0",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "isomorphic-git": "^1.25.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^8.18.0",
    "postgres": "^3.4.5",
    "universal-user-agent": "^7.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
