{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@chorus/shared-types": ["./packages/shared-types/src"],
      "@chorus/tree-sitter-utils": ["./packages/tree-sitter-utils/src"],
      "@chorus/graph-utils": ["./packages/graph-utils/src"],
      "@chorus/ui": ["./packages/ui/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
